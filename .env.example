# Copy this file to .env.local for local development. On Railway, set these as
# service variables (frontend VITE_* vars need to be present at BUILD time
# because Vite bakes them into the bundle).

# ---- Frontend (baked into the Vite bundle at build time) ----
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=sb_publishable_xxx

# ---- Server (Node process; only needed for the Node server, not the client) ----
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=sb_secret_xxx

# Stripe (see PHASE3_STRIPE_SETUP.md for how to fill these)
STRIPE_SECRET_KEY=sk_live_or_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx
STRIPE_PRICE_DAY_PASS=price_xxx
STRIPE_PRICE_LIFETIME=price_xxx
