# Copy this file to .env.local for local development. On Railway, set these as
# service variables (Build & Deploy will both need them, since VITE_* vars are
# baked into the bundle at build time).

# ---- Frontend (baked into the Vite bundle at build time) ----
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=sb_publishable_xxx

# ---- Server-only (only needed once we wire Stripe / admin actions) ----
# SUPABASE_SERVICE_ROLE_KEY=sb_secret_xxx
# STRIPE_SECRET_KEY=sk_live_xxx
# STRIPE_WEBHOOK_SECRET=whsec_xxx
# RESEND_API_KEY=re_xxx
